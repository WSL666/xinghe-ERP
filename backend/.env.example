DATABASE_URL=postgresql://product_pipeline_user:product_pipeline_dev_password@127.0.0.1:5433/product_pipeline
REDIS_URL=unix:///var/run/product-pipeline/redis.sock?db=0
APP_SECRET_KEY=change-this-dev-secret
APP_ENV=development
SESSION_COOKIE_NAME=ppe_session
SESSION_MAX_AGE_SECONDS=1209600
AUTO_VERIFY_USERS=true
POOL_MIN_SIZE=2
POOL_MAX_SIZE=20
POOL_TIMEOUT=30
POOL_MAX_IDLE=300
PIPELINE_CONCURRENCY=2
PIPELINE_MAX_PER_USER=1

step2_base_url=
step2_api_key=
step2_model=deepseek-chat

CHAT_API_KEY=
OPENAI_CHAT_BASE_URL=
CHAT_MODEL=gpt-5.5

VIBE_BASE_URL=
VIBE_API_KEY=
IMAGE_MODEL=gpt-image-2
IMAGE_SIZE=1024x1024

OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=
OSS_BUCKET=
OSS_FOLDER_1=old_image/
OSS_FOLDER_2=new_image/
OSS_DEFAULT_FOLDER=1
OSS_CDN_DOMAIN=
OSS_USE_SIGNED_URL=false
OSS_SIGN_EXPIRES=86400

# ── SMS verification (register) ──
# console: code logged + echoed in API response (dev). aliyun: real SMS via Dysmsapi.
SMS_PROVIDER=console
SMS_CODE_TTL_SECONDS=300
SMS_RESEND_COOLDOWN_SECONDS=60
SMS_DAILY_LIMIT=10
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=

# 充值/金豆接口管理员令牌(请求头 X-Admin-Token 校验, billing/router.py 使用)
ADMIN_TOKEN=生成你自己的随机串
